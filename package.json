{
  "name": "kairo-code-desktop",
  "version": "0.1.0",
  "description": "kairo-code AI Workspace - Electron Desktop App",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test",
    "verify": "npm run test && npm run build",
    "nightly": "bash scripts/nightly.sh",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder --config electron-builder.yml",
    "package:mac": "npm run build && electron-builder --mac --config electron-builder.yml",
    "package:win": "npm run build && electron-builder --win --config electron-builder.yml",
    "package:linux": "npm run build && electron-builder --linux --config electron-builder.yml"
  },
  "dependencies": {
    "@kairo/api": "file:../kairo-ts/packages/api",
    "@kairo/core": "file:../kairo-ts/packages/core",
    "@kairo/plugin": "file:../kairo-ts/packages/plugin",
    "@monaco-editor/react": "^4.7.0",
    "@types/diff": "^7.0.2",
    "chokidar": "^5.0.0",
    "diff": "^9.0.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "framer-motion": "^11.0.0",
    "monaco-editor": "^0.55.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.1",
    "shiki": "^1.22.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.1.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  }
}
